# LHN Sovereign V90 - Environment Template
# Copy this file to .env and fill locally. Never commit real credentials.

# Backend
LHN_BACKEND_HOST=127.0.0.1
LHN_BACKEND_PORT=9002
LHN_WORKSPACE_DIR=Workspace_LHN

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:9002
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:9002/stream

# Runtime mode
LHN_MODE=simulation
LHN_USE_BYBIT_TESTNET=true

# Bybit credentials
BYBIT_API_KEY=YOUR_API_KEY_HERE
BYBIT_API_SECRET=YOUR_API_SECRET_HERE

# Telegram notifications
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Optional encryption key for local secret storage
LHN_AES_KEY=YOUR_LOCAL_AES_KEY_HERE
